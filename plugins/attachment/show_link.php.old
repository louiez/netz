function get_image($imgtype){
	switch ($imgtype) {
		case "text/plain":
			$imgname = "tex.png";
			break;
		case "text/html":
			$imgname = "html.png";
			break;
		case "image/jpeg":
			$imgname = "jpeg.png";
			break;
                case "image/x-ms-bmp":
                        $imgname = "jpeg.png";
                        break;
                case "image/png":
                        $imgname = "jpeg.png";
                        break;
                case "image/gif":
                        $imgname = "jpeg.png";
                        break;
                case "image/x-icon":
                        $imgname = "jpeg.png";
                        break;
                case "audio/mpeg":
                        $imgname = "mp3.png";
                        break;
                case "audio/wav":
                        $imgname = "wav.png";
                        break;
                case "video/mpeg":
                        $imgname = "mpg.png";
                        break;
                case "video/x-ms-wmv":
                        $imgname = "wmv.png";
                        break;
                case "video/quicktime":
                        $imgname = "mov.png";
                        break;
                case "application/x-shockwave-flash":
                        $imgname = "swf.png";
                        break;
                case "application/msword":
                        $imgname = "doc.png";
                        break;
                case "application/vnd.visio":
                        $imgname = "vsd.png";
                        break;
		default:
			$imgname = "file.png";
			break;
	}
return $imgname;
}
