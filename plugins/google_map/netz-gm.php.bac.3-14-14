function resize() {
        mymap=document.getElementById("mapbuggy");
        if (window.innerHeight){
                mymap.style.height = window.innerHeight *.95;
                mymap.style.width = window.innerWidth * .95;
        }else if (document.body.clientHeight){
                mymap.style.height = document.body.clientHeight *.95;
                mymap.style.width = document.body.clientWidth * .95;
        }
} 

    
