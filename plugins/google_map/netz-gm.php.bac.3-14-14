function build_Link(site,lat,lon){
        link= "<a href='@' onclick='return update_location(\"" + site + "\",\"" + lat + "\",\"" + lon+ "\")'>"
//        link= link + "/save_location.php?site=" + site ;
//        link= link + "&lat=" + lat + "&lon=" + lon +"'>";
        link= link + "Save New location</a>";
        return link;
}
function update_location(site,lat,lon){
        if (window.XMLHttpRequest){
                // code for IE7+, Firefox, Chrome, Opera, Safari
                xmlhttp=new XMLHttpRequest();
        }else{
                // code for IE6, IE5
                xmlhttp=new ActiveXObject("Microsoft.XMLHTTP");
        }
        link=  "save_location.php?site=" + site ;
        link= link + "&lat=" + lat + "&lon=" + lon + "&";
        x= link +((new Date()).valueOf());
alert("Sending request \n"+lat + " " + lon);
        xmlhttp.open("GET",x,true);
        xmlhttp.send();
        return false 
}
function createMarker(lat,lon, waypoint_name, waypoint_info, source) {
//alert(selection);
        if (source == "zip"){
                var image = new google.maps.MarkerImage('<?php echo $_SESSION['secure'] . $_SERVER['HTTP_HOST'].dirname($_SERVER['PHP_SELF']) ?>/blank.png')
        }else if(source == "latlon"){
					if (selection == "offline"){
						var image = new google.maps.MarkerImage('<?php echo $_SESSION['secure'] . $_SERVER['HTTP_HOST'].dirname($_SERVER['PHP_SELF']) ?>/red.png');
					}else{
                var image = new google.maps.MarkerImage('<?php echo $_SESSION['secure'] . $_SERVER['HTTP_HOST'].dirname($_SERVER['PHP_SELF']) ?>/blank_green.png');
					}
        }else if(source == "closed"){
                var image = new google.maps.MarkerImage('<?php echo $_SESSION['secure'] . $_SERVER['HTTP_HOST'].dirname($_SERVER['PHP_SELF']) ?>/caution.png');
        }else if(source == "not_active"){
                var image = new google.maps.MarkerImage('<?php echo $_SESSION['secure'] . $_SERVER['HTTP_HOST'].dirname($_SERVER['PHP_SELF']) ?>/caution_yellow.png');
        }
        latlng = new google.maps.LatLng(lat,lon)
        if (<?php echo "\"" .$selection."\""?> != "site") {
                bounds.extend(latlng);
        }else{
                map.setCenter(latlng);
        }

        //var marker = new GMarker(point,markerOptions);
        var marker = new MarkerWithLabel({
                position: latlng, 
                map: map,
                icon: image,
                draggable: true,
                labelClass: "labels",
                labelStyle: {opacity: 0.75},
                labelContent:waypoint_name
        }); 
        var infowindow = new google.maps.InfoWindow({
                content: "<b>" + waypoint_name + "</b><br>" + waypoint_info + "<br>" 
                        + marker.getPosition().lat() + " "+ marker.getPosition().lng()
        });
        var infowin = new google.maps.InfoWindow({
                                        content: waypoint_name
                                });
        google.maps.event.addListener(marker, "click", function() {
                        if (infowindow) infowindow.close();
                        if (infowin) infowin.close();
                        infowindow.open(map,this);
     
        });
        google.maps.event.addListener(marker, "dragstart", function() {
                        if (infowindow) infowindow.close();
                        if (infowin) infowin.close();
        });
        google.maps.event.addListener(marker, "dragend", function(evt) {
                                if (infowindow) infowindow.close();
                                if (infowin) infowin.close();
                               myhtml= "<b>" + waypoint_name + "</b><br>" + waypoint_info;
                                 myhtml= myhtml + "<br>" + this.getPosition().lat() + " "+ this.getPosition().lng() + "<br>";
                        myhtml= myhtml + "<br>" + build_Link(waypoint_name,this.getPosition().lat(),this.getPosition().lng());

                                infowin.setContent(myhtml);
                                infowin.open(map,this);;
        });
}
