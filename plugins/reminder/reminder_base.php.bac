// local time offset
$local_time_zone_offset = (date("Z")/ 3600);
// get user time offset
$SQL_user = "SELECT * FROM USERS WHERE USERNAME = '" .$_SESSION['user']."'";
$result_user=mysql_query($SQL_user);
$row_user = mysql_fetch_assoc($result_user);
$user_time_zone_offset = $row_user['TIME_ZONE_OFFSET'];
// Calculate offset differance from user to server
$total_offset = abs($local_time_zone_offset - $user_time_zone_offset) * 60;
$foo="";
$first = 0;
// now go thru the reminders for a match
$SQL_rem = "SELECT * FROM REMINDERS WHERE USERNAME = '".$_SESSION['user']."' ORDER BY REMINDER_DATE_TIME";
$result_rem=mysql_query($SQL_rem);
        while ($row_rem = mysql_fetch_assoc($result_rem)){
		$advance= $row_rem['REMINDER_ADVANCE_TIME'] - $total_offset;
		$advance_notice_date  = mktime(date("H"),date("i")+$advance,date("s"), date("m"), date("d") , date("Y"));
		$advance_notice_date  = date("Y-m-d G:i:s",$advance_notice_date);
		$SQL_item = "SELECT * FROM REMINDERS WHERE ";
		$SQL_item .= "USERNAME = '".$_SESSION['user']."' ";
		$SQL_item .= "AND REMINDER_NAME = '".$row_rem['REMINDER_NAME']."' ";
		$SQL_item .= "AND REMINDER_DATE_TIME < '".$advance_notice_date."'";
		$result_item = mysql_query($SQL_item);
		//echo $SQL_item . "<br>";	
		if ($row_item = mysql_fetch_assoc($result_item)){
			if (trim($row_item['REMINDER_NAME']) != ""){
				// remove any CR/LF chars from description javascript don't like it
				//$r=array(Chr(13),Chr(10));
				//$d=str_replace($r, "\\n",htmlentities($row_item['DESCRIPTION'], ENT_QUOTES));
                                $r=array(Chr(13),Chr(10),Chr(39),Chr(44));
                                $s=array("\\n","\\n","","");
                               $d=str_replace($r, $s,$row_item['DESCRIPTION']);
				if ($first == 0){
					$first_dec="document.getElementById('alert_description').value='".$d."'; \n";$first =1;
				}
				$foo .= "addRowDOM('".htmlentities($row_item['REMINDER_NAME'])."','";
				$foo .= $row_item['REMINDER_DATE_TIME']."','";
				$foo .= $d."','";
				$foo .=$row_item['REMINDER_ID']."','display_table'); \n" ;
			}
		}		

        }
if ($foo != ""){
echo "<script type=\"text/javascript\">";
echo "document.getElementById('display_div').style.left= \"450px\";";
echo $foo;
echo $first_dec;
echo "addTableRolloverEffect('display_table','tableRollOverEffect1','tableRowClickEffect1');";
echo "</script>";
}
